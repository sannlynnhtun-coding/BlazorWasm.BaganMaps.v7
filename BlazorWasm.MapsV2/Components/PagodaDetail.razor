@using BlazorWasm.MapsV2.Models

<div class="fixed inset-y-0 right-0 z-[100] w-full sm:w-[450px] bg-card dark:bg-card-dark shadow-2xl transition-transform duration-500 ease-in-out transform @(IsOpen ? "translate-x-0" : "translate-x-full") border-l border-muted dark:border-muted-dark flex flex-col">
    @if (Pagoda != null)
    {
        <!-- Header Image -->
        <div class="relative h-64 bg-muted overflow-hidden">
            @if (!string.IsNullOrEmpty(Detail?.ImgUrl))
            {
                <img src="@Detail.ImgUrl" class="w-full h-full object-cover" alt="@Pagoda.PagodaMmName" />
            }
            else
            {
                <div class="w-full h-full bg-gradient-to-br from-primary/20 to-secondary/20 flex items-center justify-center p-12">
                     <svg xmlns="http://www.w3.org/2000/svg" class="w-32 h-32 text-primary/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
            }
            
            <button @onclick="OnClose" class="absolute top-4 right-4 p-2 bg-black/20 backdrop-blur-md rounded-full text-white hover:bg-black/40 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>

            <div class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-black/80 to-transparent">
                <h2 class="text-2xl font-bold text-white">@Pagoda.PagodaMmName</h2>
                <p class="text-sm text-white/70 font-medium tracking-wide">@Pagoda.PagodaEngName</p>
            </div>
        </div>

        <!-- Content -->
        <div class="flex-1 overflow-y-auto p-8 space-y-6">
            <div class="flex items-center gap-4">
                <div class="flex-1 p-4 bg-muted/30 dark:bg-muted-dark/30 rounded-2xl border border-muted dark:border-muted-dark text-center">
                    <p class="text-[10px] text-foreground/40 uppercase font-bold tracking-widest mb-1">Latitude</p>
                    <p class="text-sm font-mono font-medium">@Pagoda.Latitude.ToString("F4")</p>
                </div>
                <div class="flex-1 p-4 bg-muted/30 dark:bg-muted-dark/30 rounded-2xl border border-muted dark:border-muted-dark text-center">
                    <p class="text-[10px] text-foreground/40 uppercase font-bold tracking-widest mb-1">Longitude</p>
                    <p class="text-sm font-mono font-medium">@Pagoda.Longitude.ToString("F4")</p>
                </div>
            </div>

            <div class="prose dark:prose-invert max-w-none">
                <h3 class="text-lg font-bold text-primary mb-3">About this Pagoda</h3>
                @if (!string.IsNullOrEmpty(Detail?.Description))
                {
                    <p class="text-foreground/80 dark:text-foreground-dark/80 leading-relaxed whitespace-pre-line">
                        @Detail.Description
                    </p>
                }
                else
                {
                    <p class="text-foreground/40 italic">No description available for this ancient wonder.</p>
                }
            </div>

            <div class="pt-6 border-t border-muted dark:border-muted-dark">
                <button class="w-full py-4 bg-primary text-white rounded-2xl font-bold hover:shadow-lg hover:shadow-primary/20 transition-all active:scale-[0.98] flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    Get Directions
                </button>
            </div>
        </div>
    }
</div>

@if (IsOpen)
{
    <div @onclick="OnClose" class="fixed inset-0 z-[90] bg-black/10 backdrop-blur-[2px]"></div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public BaganMapInfoModel? Pagoda { get; set; }
    [Parameter] public BaganMapInfoDetailModel? Detail { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
}
