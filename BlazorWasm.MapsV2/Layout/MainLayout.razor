@inherits LayoutComponentBase
@inject ThemeService ThemeService
@implements IDisposable

<div class="@(ThemeService.IsDarkMode ? "dark" : "")">
    <div class="relative min-h-screen bg-background dark:bg-background-dark text-foreground dark:text-foreground-dark font-sans transition-colors duration-300">
        <!-- Sidebar -->
        <aside class="fixed inset-y-0 left-0 z-50 w-72 bg-card/80 dark:bg-card-dark/80 backdrop-blur-xl border-r border-muted dark:border-muted-dark transform transition-transform duration-300 ease-in-out @(isSidebarOpen ? "translate-x-0" : "-translate-x-full") lg:translate-x-0">
            <div class="flex flex-col h-full">
                <div class="p-6 border-b border-muted dark:border-muted-dark bg-primary/5 flex items-center gap-4">
                    <img src="images/logo.svg" alt="Bagan Maps Logo" class="w-12 h-12" />
                    <div>
                        <h1 class="text-2xl font-bold text-primary dark:text-primary-dark tracking-tight">Bagan Maps</h1>
                        <p class="text-[10px] text-foreground/60 dark:text-foreground-dark/60 uppercase tracking-widest font-bold">Adventure Awaits</p>
                    </div>
                </div>
                
                <nav class="flex-1 overflow-y-auto p-4 space-y-2">
                    <NavMenu />
                </nav>

                <div class="p-4 border-t border-muted dark:border-muted-dark flex items-center justify-between">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center text-primary">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        </div>
                        <div>
                            <p class="text-sm font-semibold">Traveler</p>
                            <p class="text-xs opacity-60">Pro Explorer</p>
                        </div>
                    </div>
                    <button @onclick="ToggleTheme" class="p-2 rounded-xl bg-muted/50 dark:bg-muted-dark/50 hover:bg-muted dark:hover:bg-muted-dark transition-colors">
                        @if (ThemeService.IsDarkMode)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" class="text-yellow-400" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
                        }
                    </button>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="lg:ml-72 h-screen relative overflow-hidden">
            <!-- Top Bar -->
            <header class="absolute top-0 left-0 right-0 z-40 p-4 flex items-center justify-between pointer-events-none">
                <button @onclick="ToggleSidebar" class="p-3 rounded-2xl bg-card/90 dark:bg-card-dark/90 shadow-xl backdrop-blur-lg lg:hidden pointer-events-auto border border-muted dark:border-muted-dark">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
                </button>
                
                <div class="hidden lg:flex items-center gap-4 bg-card/90 dark:bg-card-dark/90 p-2 rounded-2xl shadow-xl backdrop-blur-lg pointer-events-auto border border-muted dark:border-muted-dark w-96 ml-4">
                    <div class="pl-2 text-foreground/40">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    </div>
                    <input type="text" placeholder="Search Pagodas..." class="bg-transparent border-none focus:ring-0 text-sm w-full" />
                </div>

                <div class="flex items-center gap-3 pointer-events-auto">
                    <div class="bg-card/90 dark:bg-card-dark/90 p-2 px-4 rounded-2xl shadow-xl backdrop-blur-lg border border-muted dark:border-muted-dark flex items-center gap-2">
                        <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
                        <span class="text-xs font-semibold uppercase tracking-wider">Map Live</span>
                    </div>
                </div>
            </header>

            <!-- Page Body (The Map) -->
            <div class="h-full w-full">
                @Body
            </div>
        </main>

        <!-- Overlay -->
        @if (isSidebarOpen)
        {
            <div @onclick="ToggleSidebar" class="fixed inset-0 z-40 bg-black/40 backdrop-blur-sm lg:hidden transition-opacity"></div>
        }
    </div>
</div>

@code {
    private bool isSidebarOpen = false;

    protected override void OnInitialized()
    {
        ThemeService.OnThemeChanged += HandleThemeChanged;
    }

    private void HandleThemeChanged()
    {
        StateHasChanged();
    }

    private void ToggleSidebar()
    {
        isSidebarOpen = !isSidebarOpen;
    }

    private void ToggleTheme()
    {
        ThemeService.ToggleTheme();
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= HandleThemeChanged;
    }
}
