@using BlazorWasm.MapsV2.Models
@inject MapService MapService

<div class="space-y-6">
    <div>
        <h3 class="px-3 text-xs font-semibold text-foreground/40 uppercase tracking-widest mb-4">Main Menu</h3>
        <div class="space-y-1">
            <NavLink class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all hover:bg-primary/10 hover:text-primary group" href="" Match="NavLinkMatch.All">
                <div class="text-foreground/60 group-[.active]:text-primary transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </div>
                Home
            </NavLink>
        </div>
    </div>

    <div>
        <h3 class="px-3 text-xs font-semibold text-foreground/40 uppercase tracking-widest mb-4">Travel Routes</h3>
        @if (travelRoutes != null)
        {
            <div class="space-y-1">
                @foreach (var item in travelRoutes)
                {
                    string url = item.TravelRouteId;
                    <NavLink class="flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-medium transition-all hover:bg-secondary/20 hover:text-primary group border border-transparent hover:border-secondary/30" href="@url">
                        <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-secondary/10 flex items-center justify-center text-secondary group-hover:bg-secondary/20 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                        </div>
                        <div class="flex flex-col">
                            <span>@item.TravelRouteName</span>
                            <span class="text-[10px] opacity-50 font-normal truncate max-w-[150px]">Explore the ancient wonders</span>
                        </div>
                    </NavLink>
                }
            </div>
        }
        else
        {
            <div class="px-3 py-4 text-center">
                <div class="inline-block animate-spin rounded-full h-4 w-4 border-2 border-primary/30 border-t-primary"></div>
            </div>
        }
    </div>

    <div class="pt-4">
        <div class="p-4 bg-primary/5 rounded-2xl border border-primary/10">
            <p class="text-[10px] font-bold text-primary uppercase mb-1">New Feature</p>
            <p class="text-xs font-medium mb-2">Offline maps available now for pro members.</p>
            <button class="w-full py-2 bg-primary text-white rounded-lg text-xs font-bold hover:bg-primary/90 transition-colors">Upgrade Now</button>
        </div>
    </div>
</div>

@code {
    private List<TravelRouteModel>? travelRoutes;

    protected override async Task OnInitializedAsync()
    {
        await MapService.LoadDataAsync();
        travelRoutes = MapService.TravelRouteList();
    }
}
